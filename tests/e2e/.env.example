# Copy to .env and fill in API keys
# At least one LLM API key required for migration/extraction tests

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

OPENCLAW_GATEWAY_TOKEN=keyoku-test-token
KEYOKU_SESSION_TOKEN=test-token

KEYOKU_EXTRACTION_PROVIDER=gemini
KEYOKU_EXTRACTION_MODEL=gemini-3.1-flash-lite-preview
